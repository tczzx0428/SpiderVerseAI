def cmd_rules(args):
    """Rules command with optional subcommand: get / update / edit."""
    # No subcommand or subcommand is 'get' — read rules
    if not args or args[0] == "get":
        r = check(api("get", "/api/config/template"))
        print(r.json().get("value", ""))
        return

    sub = args[0]
    rest = args[1:]

    if sub == "update":
        import argparse
        p = argparse.ArgumentParser()
        p.add_argument("--file", default=None, help="从文件读取内容（不提供则从 stdin 读）")
        opts = p.parse_args(rest)

        if opts.file:
            content = Path(opts.file).read_text(encoding="utf-8")
        else:
            if sys.stdin.isatty():
                # No file and no piped stdin: open editor
                _rules_edit_in_editor()
                return
            else:
                content = sys.stdin.read()

        check(api("put", "/api/config/template", json={"value": content}))
        print("✅ 规范已更新")
        return

    if sub == "edit":
        _rules_edit_in_editor()
        return

    print(f"❌ 未知子命令: {sub}")
    print("用法: pt rules [get|update [--file FILE]|edit]")
    sys.exit(1)


def _rules_edit_in_editor():
    """Fetch current rules, open in $EDITOR (or nano), then PUT on save."""
    r = check(api("get", "/api/config/template"))
    current = r.json().get("value", "")

    with tempfile.NamedTemporaryFile(suffix=".txt", mode="w", delete=False, encoding="utf-8") as tf:
        tf.write(current)
        tmp_path = tf.name

    editor = os.environ.get("EDITOR", "nano")
    import subprocess
    subprocess.call([editor, tmp_path])

    new_content = Path(tmp_path).read_text(encoding="utf-8")
    os.unlink(tmp_path)

    if new_content == current:
        print("内容未修改，跳过更新")
        return

    check(api("put", "/api/config/template", json={"value": new_content}))
    print("✅ 规范已更新")


