    if app["status"] != "running":
        print(f"⚠️  应用当前状态: {app['status']}，可能无法访问")
    url = get_url()
    target = f"{url}/apps/{app['slug']}/"
    import subprocess
    subprocess.run(["open", target] if sys.platform == "darwin" else
                   ["xdg-open", target] if sys.platform.startswith("linux") else
                   ["start", target], shell=(sys.platform == "win32"))
    print(f"打开: {target}")


def cmd_history(args):
    """Show run history. With a slug, shows history for that app.
    Without a slug, shows all recent runs across all apps."""
    if not args:
        # Global history: all recent runs
        r = check(api("get", "/api/apps/history/runs", params={"size": 50}))
        records = r.json()
        if not records:
            print("暂无运行历史")
            return
        print(f"{'时间':<22} {'应用':<20} {'用户':<15} {'摘要'}")
        print("-" * 85)
        for rec in records[:50]:
            ts = rec.get("timestamp", "")[:19]
            app_name = rec.get("app_name", rec.get("app_slug", ""))
            user = rec.get("username", "")
            summary = rec.get("summary", "")[:40]
            print(f"{ts:<22} {app_name:<20} {user:<15} {summary}")
        return

    # Per-app history
    app = find_app_by_slug(args[0])
    r = check(api("get", f"/api/apps/{app['id']}/history"))
    records = r.json()
    if not records:
