    except Exception as e:
        print(f"❌ 同步失败: {e}")
        sys.exit(1)


def cmd_config(args):
    """查看或更新团队 AI 配置"""
    sub = args[0] if args else "get"
    rest = args[1:]

    if sub in ("get", "show"):
        r = check(api("get", "/api/auth/team-config"))
        data = r.json()
        print("团队 AI 配置:")
        for key, value in data.items():
            display = value
            if key == "api_key" and value and len(value) > 8:
                display = value[:4] + "***" + value[-4:]
            print(f"  {key}: {display}")
        return

    if sub == "set":
        import argparse
        p = argparse.ArgumentParser()
        p.add_argument("--api-key", default=None)
        p.add_argument("--base-url", default=None)
        p.add_argument("--codex-model", default=None)
        p.add_argument("--openclaw-model", default=None)
        opts = p.parse_args(rest)
        body = {}
        if opts.api_key is not None:       body["api_key"] = opts.api_key
        if opts.base_url is not None:      body["base_url"] = opts.base_url
        if opts.codex_model is not None:   body["codex_model"] = opts.codex_model
        if opts.openclaw_model is not None: body["openclaw_model"] = opts.openclaw_model
        if not body:
            print("❌ 请提供至少一个要更新的字段")
            sys.exit(1)
        r = check(api("put", "/api/admin/team-config", json=body))
        updated = r.json().get("updated", [])
        print(f"✅ 已更新: {', '.join(updated)}")
        return

    print(f"❌ 未知子命令: {sub}")
    print("用法: pt config [get|set --api-key K --base-url U ...]")
    sys.exit(1)


def cmd_status(_args):
    """检查平台连通性和登录状态，类似 ping。"""
    cfg = load_config()
    url = cfg.get("url", "").rstrip("/")
    token = cfg.get("token", "")
    if not url or not token:
        print("❌ 未登录，请先运行: pt login")
        sys.exit(1)
    try:
        r = requests.get(f"{url}/api/auth/me",
                         headers={"Authorization": f"Bearer {token}"},
                         timeout=10)
        if r.status_code == 200:
            u = r.json()
            print(f"✅ 平台连接正常")
            print(f"   平台地址: {url}")
            print(f"   登录用户: {u['username']} ({u['role']})")
            print(f"   服务状态: OK")
        else:
            print(f"⚠️  平台响应异常 ({r.status_code})")
            print(f"   平台地址: {url}")
            print(f"   服务状态: 异常")
    except requests.ConnectionError:
        print(f"❌ 无法连接到平台")
        print(f"   平台地址: {url}")
        print(f"   服务状态: 无法访问")
        sys.exit(1)


def cmd_list(args):
    import argparse
    p = argparse.ArgumentParser()
    p.add_argument("--status", help="过滤状态: running/stopped/building/failed")
    opts = p.parse_args(args)
    params = {"size": 200}
    if opts.status:
        params["status"] = opts.status
    r = check(api("get", "/api/apps", params=params))
    data = r.json()
    items = data.get("items", [])
    if not items:
        print("暂无应用")
        return
    platform_url = get_url()
    print(f"{'ID':<5} {'名称':<20} {'Slug':<20} {'状态':<15} {'所有者':<15} {'URL'}")
    print("-" * 100)
    for a in items:
        app_url = f"{platform_url}/apps/{a['slug']}/" if a["status"] == "running" else ""
        print(f"{a['id']:<5} {a['name']:<20} {a['slug']:<20} {fmt_status(a['status']):<15} {a['owner']['username']:<15} {app_url}")
    print(f"\n共 {data['total']} 个应用")


def cmd_deploy(args):
    import argparse
    p = argparse.ArgumentParser()
    p.add_argument("dir", nargs="?", help="应用目录（默认当前目录）")
    p.add_argument("--dir", dest="dir_flag", default=None, help="应用目录（--dir 方式）")
    p.add_argument("--name", default=None, help="应用名称（跳过交互提示）")
    p.add_argument("--slug", default=None, help="URL Slug（跳过交互提示）")
    p.add_argument("--desc", default=None, help="应用描述（跳过交互提示）")
    opts = p.parse_args(args)

    # --dir flag takes precedence over positional arg
    dir_arg = opts.dir_flag or opts.dir
    src_dir = Path(dir_arg).resolve() if dir_arg else Path.cwd()
    if not src_dir.exists():
        print(f"❌ 目录不存在: {src_dir}")
        sys.exit(1)
    if not (src_dir / "app.py").exists():
        print(f"❌ 目录中找不到 app.py: {src_dir}")
        sys.exit(1)

    meta_path = src_dir / META_FILE
    meta = json.loads(meta_path.read_text()) if meta_path.exists() else {}
    app_id = meta.get("app_id")

    # ── 新建应用 ──────────────────────────────────────────────────────────────
    if not app_id:
        default_name = src_dir.name
        default_slug = default_name.lower().replace("_", "-").replace(" ", "-")

        # Use flags if provided, otherwise fall back to interactive prompts
        if opts.name is not None and opts.slug is not None:
            name = opts.name
            slug = opts.slug
            desc = opts.desc if opts.desc is not None else ""
        else:
            print(f"首次部署，请填写应用信息（留空使用默认值）")
            name = opts.name if opts.name is not None else (input(f"应用名称 [{default_name}]: ").strip() or default_name)
            slug = opts.slug if opts.slug is not None else (input(f"URL Slug [{default_slug}]: ").strip() or default_slug)
            desc = opts.desc if opts.desc is not None else input("应用描述: ").strip()

        r = check(api("post", "/api/apps", json={"name": name, "slug": slug, "description": desc}), ok_codes=(200, 201))
        app_id = r.json()["id"]
        meta = {"app_id": app_id, "slug": slug, "name": name}
        meta_path.write_text(json.dumps(meta, indent=2, ensure_ascii=False))
        print(f"✅ 应用已创建: {name} (id={app_id})")
    else:
        slug = meta.get("slug", "")
        name = meta.get("name", str(app_id))
        print(f"更新应用: {name} (id={app_id})")

    # ── 打包上传 ──────────────────────────────────────────────────────────────
    print("📦 打包中...")
    zip_path = make_zip(src_dir)
    try:
        size_kb = os.path.getsize(zip_path) / 1024
        print(f"   大小: {size_kb:.1f} KB，上传中...")
        with open(zip_path, "rb") as f:
            r = check(api("post", f"/api/apps/{app_id}/upload",
                          files={"file": ("app.zip", f, "application/zip")}))
        print("✅ 上传完成")
    finally:
        os.unlink(zip_path)

    # ── 触发部署 ──────────────────────────────────────────────────────────────
    check(api("post", f"/api/apps/{app_id}/deploy"), ok_codes=(200, 202))
    print("🚀 部署任务已提交，等待构建...")

    # ── 轮询状态 ──────────────────────────────────────────────────────────────
    url = get_url()
    dots = 0
    for _ in range(80):
        time.sleep(3)
        r = api("get", f"/api/apps/{app_id}")
        if r.status_code != 200:
            continue
        app = r.json()
        status = app.get("status", "")
        dots += 1
        print(f"\r   构建中{'.' * (dots % 4 + 1)}   ", end="", flush=True)
        if status == "running":
            print(f"\n✅ 部署成功！")
            print(f"   访问地址: {url}/apps/{slug}/")
            return
        if status == "failed":
            print(f"\n❌ 部署失败，查看日志:")
            log = app.get("build_log", "") or ""
            lines = log.strip().splitlines()
            for line in lines[-20:]:
                print(f"   {line}")
            print(f"\n更多日志: pt logs {slug}")
            sys.exit(1)

    print("\n⚠️  构建超时，可用 pt logs 查看进度")


