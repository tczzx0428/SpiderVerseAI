def cmd_login(args):
    import argparse
    p = argparse.ArgumentParser()
    p.add_argument("--url", default="http://YOUR_PLATFORM_HOST")
    p.add_argument("--username", default=None)
    p.add_argument("--password", default=None)
    opts = p.parse_args(args)
    url = opts.url.rstrip("/")

    username = opts.username or input("账号: ").strip()
    password = opts.password or input("密码: ").strip()

    try:
        r = requests.post(f"{url}/api/auth/login",
                          json={"username": username, "password": password},
                          timeout=10)
    except requests.ConnectionError:
        print(f"❌ 无法连接到 {url}")
        sys.exit(1)

    if r.status_code != 200:
        try:
            detail = r.json().get("detail", r.text)
        except Exception:
            detail = r.text
        print(f"❌ 登录失败: {detail}")
        sys.exit(1)

    data = r.json()
    cfg = {"url": url, "token": data["access_token"], "username": data["user"]["username"]}
    save_config(cfg)
    role = data["user"].get("role", "")
    print(f"✅ 登录成功！欢迎 {data['user']['username']} ({role})")
    print(f"   平台: {url}")

    # 拉取团队 AI 配置并写入 Codex / OpenClaw
    try:
        _sync_ai_config(url, data["access_token"])
    except Exception:
        pass


def cmd_logout(_args):
    try:
        api("post", "/api/auth/logout")
    except SystemExit:
        pass
    cfg = load_config()
    cfg.pop("token", None)
    save_config(cfg)
    print("✅ 已退出登录")


