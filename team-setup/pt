# ── 常量 ──────────────────────────────────────────────────────────────────────
CONFIG_FILE  = Path.home() / ".pe" / "config.json"
APPS_DIR     = Path.home() / "Desktop" / "pe-apps"
META_FILE    = ".pe-space.json"
EXCLUDE_DIRS = {".git", "__pycache__", ".venv", "venv", "node_modules", ".mypy_cache", ".pytest_cache"}
EXCLUDE_EXTS = {".pyc", ".pyo", ".DS_Store"}

# ── 配置读写 ──────────────────────────────────────────────────────────────────
def load_config() -> dict:
    if CONFIG_FILE.exists():
        return json.loads(CONFIG_FILE.read_text())
    return {}

def save_config(cfg: dict):
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2, ensure_ascii=False))

def get_url() -> str:
    cfg = load_config()
    url = cfg.get("url", "")
    if not url:
        print("❌ 未登录，请先运行: pt login --url http://YOUR_PLATFORM_HOST")
        sys.exit(1)
    return url.rstrip("/")

def get_token() -> str:
    cfg = load_config()
    token = cfg.get("token", "")
    if not token:
        print("❌ 未登录，请先运行: pt login")
        sys.exit(1)
    return token

# ── HTTP 工具 ─────────────────────────────────────────────────────────────────
def api(method: str, path: str, **kwargs) -> requests.Response:
    url   = get_url()
    token = get_token()
    headers = kwargs.pop("headers", {})
    headers["Authorization"] = f"Bearer {token}"
    try:
        r = requests.request(method, url + path, headers=headers, timeout=60, **kwargs)
    except requests.ConnectionError:
        print(f"❌ 无法连接到 {url}，请检查网络或平台地址")
        sys.exit(1)
    return r

def check(r: requests.Response, ok_codes=(200, 201, 202, 204)):
    if r.status_code not in ok_codes:
        try:
            detail = r.json().get("detail", r.text)
        except Exception:
            detail = r.text
        print(f"❌ 请求失败 ({r.status_code}): {detail}")
        sys.exit(1)
    return r

# ── 工具函数 ──────────────────────────────────────────────────────────────────
def find_app_by_slug(slug: str) -> dict:
    r = check(api("get", "/api/apps", params={"size": 200}))
    items = r.json().get("items", [])
    for item in items:
        if item["slug"] == slug:
            return item
    print(f"❌ 找不到应用: {slug}")
    sys.exit(1)

def make_zip(src_dir: Path) -> str:
    tmp = tempfile.mktemp(suffix=".zip")
    with zipfile.ZipFile(tmp, "w", zipfile.ZIP_DEFLATED) as zf:
        for f in src_dir.rglob("*"):
            # 排除目录本身
            if f.is_dir():
                continue
            # 排除隐藏文件和特定目录/扩展名
            parts = f.relative_to(src_dir).parts
            if any(p in EXCLUDE_DIRS or p.startswith(".") for p in parts):
                continue
            if f.suffix in EXCLUDE_EXTS or f.name in {".DS_Store", META_FILE}:
                continue
            zf.write(f, f.relative_to(src_dir))
    return tmp

def fmt_status(s: str) -> str:
    icons = {"running": "🟢", "stopped": "🔴", "building": "🟡", "failed": "❌", "pending": "⏳"}
    return f"{icons.get(s, '❓')} {s}"

def fmt_size(size_bytes: int) -> str:
    """Format file size in human-readable form."""
    if size_bytes < 1024:
        return f"{size_bytes}B"
    elif size_bytes < 1024 * 1024:
        return f"{size_bytes / 1024:.1f}KB"
    else:
        return f"{size_bytes / (1024 * 1024):.1f}MB"

def lookup_user_id(id_or_username: str) -> int:
    """If id_or_username is a number return it as int; otherwise look up by username."""
    if id_or_username.isdigit():
        return int(id_or_username)
    r = check(api("get", "/api/admin/users"))
    users = r.json()
    for u in users:
        if u["username"] == id_or_username:
            return u["id"]
    print(f"❌ 找不到用户: {id_or_username}")
    sys.exit(1)

# ── AI 配置同步 ──────────────────────────────────────────────────────────────
def _sync_ai_config(url: str, token: str):
    """从后端拉取团队 AI 配置并写入 Codex / OpenClaw / Skills"""
    headers = {"Authorization": f"Bearer {token}"}

    # 拉取 team-config
    tc = requests.get(f"{url}/api/auth/team-config", headers=headers, timeout=10)
    if tc.status_code != 200:
        print(f"⚠️  获取 team-config 失败: {tc.status_code}")
        return
    tc_data = tc.json()
    api_key        = tc_data.get("api_key", "")
    base_url       = tc_data.get("base_url", "")
    codex_model    = tc_data.get("codex_model", "gpt-5.2-codex")
    openclaw_model = tc_data.get("openclaw_model", "gpt-5.2")

    if not api_key:
        print("⚠️  服务器未配置 TEAM_API_KEY，跳过")
        return

    # 写 Codex 配置
    codex_dir = Path.home() / ".codex"
    codex_dir.mkdir(exist_ok=True)
    (codex_dir / "auth.json").write_text(
        json.dumps({"OPENAI_API_KEY": api_key}))
    (codex_dir / "config.toml").write_text(
        f'model_provider = "team"\n'
        f'model = "{codex_model}"\n'
        f'model_reasoning_effort = "high"\n'
        f'disable_response_storage = true\n'
        f'preferred_auth_method = "apikey"\n\n'
        f'[model_providers.team]\n'
        f'name = "team"\n'
        f'base_url = "{base_url}"\n'
        f'wire_api = "responses"\n'
    )

    # 写 OpenClaw 配置
    oclaw_cfg = Path.home() / ".openclaw" / "openclaw.json"
    if oclaw_cfg.exists():
        try:
            oc = json.loads(oclaw_cfg.read_text())
            providers = oc.setdefault("models", {}).setdefault("providers", {})
            no_provider_yet = not providers
            providers["team"] = {
                "baseUrl": base_url, "apiKey": api_key,
                "api": "openai-completions",
                "models": [{"id": openclaw_model, "name": "GPT-5.2 (Team)",
                            "contextWindow": 1000000, "maxTokens": 16000,
                            "reasoning": False, "input": ["text"],
                            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0}}]
            }
            if no_provider_yet:
                oc.setdefault("agents", {}).setdefault("defaults", {})["model"] = {
                    "primary": f"team/{openclaw_model}"
                }
            oclaw_cfg.write_text(json.dumps(oc, indent=2, ensure_ascii=False))
        except Exception as e:
            print(f"⚠️  OpenClaw 配置写入失败: {e}")

    # 同步 skills
    try:
        sr = requests.get(f"{url}/api/auth/skills", headers=headers, timeout=10)
        if sr.status_code == 200:
            skills_base = Path.home() / ".openclaw" / "skills"
            synced = []
            for skill in sr.json():
                sname = skill.get("name", "").strip()
                scontent = skill.get("content", "")
                if not sname:
                    continue
                skill_dir = skills_base / sname
                skill_dir.mkdir(parents=True, exist_ok=True)
                (skill_dir / "SKILL.md").write_text(scontent, encoding="utf-8")
                synced.append(sname)
            if synced:
                print(f"   Skills 已同步: {', '.join(synced)}")
    except Exception:
        pass

    print("   AI 配置已同步")


