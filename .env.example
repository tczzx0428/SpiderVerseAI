POSTGRES_PASSWORD=changeme123
JWT_SECRET=your-super-secret-key-change-this-in-production
# Linux 服务器用 172.17.0.1，Mac Docker Desktop 用 host.docker.internal
HOST_IP=host.docker.internal

# App 源码和数据在宿主机上的绝对路径
HOST_UPLOAD_DIR=/opt/tool-platform/uploads

# 团队 AI 服务配置（首次启动时写入数据库，之后可通过 pe config set 更新）
TEAM_API_KEY=sk-your-api-key-here
TEAM_BASE_URL=http://your-ai-service-host:3006/v1
CODEX_MODEL=gpt-5.2-codex
OPENCLAW_MODEL=gpt-5.2

# AI 创作应用功能配置（用于「创作应用」功能）
# 如果不设置，会使用上面的 TEAM_API_KEY 和 TEAM_BASE_URL
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=http://your-ai-service-host:3006/v1
AI_MODEL=gpt-4o-mini
AI_CODE_MODEL=gpt-4o
